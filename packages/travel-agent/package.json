{
	"name": "@mariozechner/pi-travel-agent",
	"version": "0.0.1",
	"description": "Travel planning agent built on pi-agent-core and pi-ai",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rimraf dist",
		"test": "npx tsx ../../node_modules/vitest/dist/cli.js --run",
		"eval:stage1": "promptfoo eval -c promptfooconfig.stage1.yaml -j 1"
	},
	"bin": {
		"travel-agent": "dist/cli.js"
	},
	"dependencies": {
		"@browserbasehq/stagehand": "3.0.8",
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "^0.34.14",
		"chalk": "^5.4.1",
		"playwright": "^1.59.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"rimraf": "^6.1.2",
		"tsx": "^4.21.2",
		"typescript": "^5.9.2",
		"vitest": "^3.2.6"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"license": "MIT"
}
